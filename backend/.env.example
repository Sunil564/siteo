# --- App ---
ENV=development
DEBUG=true
APP_NAME=SITEO API
API_V1_PREFIX=/api/v1

# --- Database (new Supabase Postgres project) ---
# Use the connection-pooler URL for serverless / Render, direct URL for migrations.
DATABASE_URL=postgresql+psycopg2://postgres:password@db.<project>.supabase.co:5432/postgres

# --- CORS (comma-separated frontend origins) ---
CORS_ORIGINS=http://localhost:3000,https://siteo.in,https://www.siteo.in

# --- JWT / auth ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# Cookies: set COOKIE_SECURE=false only for local http dev.
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=.siteo.in

# --- TOTP ---
TOTP_ISSUER=SITEO Admin

# --- Initial super admin seed (change the password after first login) ---
SEED_SUPERADMIN_USERNAME=admin
SEED_SUPERADMIN_PASSWORD=ChangeMe123!

# --- Enquiry numbering ---
ENQUIRY_PREFIX=SITEO-ENQ

# --- WhatsApp (Meta Cloud API via Vahini WABA) — transactional only ---
# Runtime on/off is the settings_kv `whatsapp_enabled` toggle (admin-controlled);
# these are the credentials/config it needs when on. Sends no-op when off.
WHATSAPP_ENABLED=false
WHATSAPP_PHONE_NUMBER_ID=
# WABA id — required to verify template language + variable count before sending.
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_DEFAULT_LANG=en
WHATSAPP_TIMEOUT_SECONDS=10
# Event-confirmation template names (mode -> template). hybrid uses the physical one.
WHATSAPP_TEMPLATE_EVENT_VIRTUAL=event_confirm_virtual
WHATSAPP_TEMPLATE_EVENT_PHYSICAL=event_confirm_physical

# --- Payments (Razorpay) — dormant, behind settings toggle ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Monitoring ---
SENTRY_DSN=

# --- Rate limiting ---
RATE_LIMIT_DEFAULT=100/minute
